\newcommand{\grid}[4]{
    \begin{center}
\resizebox{\linewidth}{!}{
	\begin{tikzpicture}
\draw[thick,<->] (#1,0) -- (#2,0);
\draw[thick,<->] (0,#3) -- (0,#4);
\draw[step=1cm,gray,very thin] (#1,#3) grid (#2,#4);
\foreach \x in {#1,...,#2}
   \draw (\x cm,1pt) -- (\x cm,-1pt) node[anchor=north] {$\x$};
\foreach \y in {#3,...,#4}
    \draw (1pt,\y cm) -- (-1pt,\y cm) node[anchor=east] {$\y$};
    \end{tikzpicture}
}
    \end{center}
} 

