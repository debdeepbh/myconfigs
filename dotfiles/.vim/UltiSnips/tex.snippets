#${1:a text}
#${1/\w+\s*/\u$0/}
#endsnippet


snippet bib "bibliography" b
\bibliographystyle{${1:abbrv}}
\bibliography{$2}
$0
endsnippet

snippet subfig "multiple figures with subfig pkg" b
\begin{figure}[htpb]
\centering
    \subfloat[]{\label{fig:$1}
        \includegraphics[width=0.5\linewidth]{${1:path}}
    }
    \subfloat[]{\label{fig:$2}
	 \includegraphics[width=0.5\linewidth]{${2:path}}
    }\\
\caption{${3:full caption}}%
\label{fig:$3}
\end{figure}
endsnippet


#######################################################################
#                           Clear Snippets                            #
#######################################################################

#  removing to avoid expanding \(eq)ref when \ is present
clearsnippets \

snippet color "textcolor"
\textcolor{${1:blue}}{$2}$0
endsnippet

snippet _pde "pde template"
\documentclass[12pt]{article}
\usepackage{$HOME/Templates/pde} % sty file
\usepackage[top=2cm, bottom=2cm, right=2cm, left=1.5cm]{geometry}

\title{${1:Title}}
\date{}
\author{${2:Debdeep Bhattacharya}}
\begin{document}
\maketitle
$0

\end{document}
endsnippet

snippet _exam "exam format"
\documentclass[12pt,addpoints]{exam}
\usepackage{$HOME/Templates/exam} % sty file
\usepackage{$HOME/Templates/pde} % sty file
\formattrue
% \formatfalse 

\begin{document}
\titleshort{${1:Exam 1}}
\pointtime
\\
\namebox
\instructionscc

\begin{questions} 
    \question [5] $0

\end{questions}


% \scratch
\end{document}
endsnippet

snippet ifr "formatting"
\ifformat
${1:\\newpage}
\fi	
$0
endsnippet


snippet boxr "insert answer box"
\ifformat
\vspace{${4:0}cm}
\boxright{${2:\linewidth}}{${3:1}cm}{${1:Ans:}}
\fi
$0
endsnippet

snippet sympy "sympy block " w
sympy $1 sympy$0
endsnippet

priority 10000
snippet 'sympy(.*)sympy' "evaluate sympy" wr
`!p
from sympy import *
x, y, z, t = symbols('x y z t')
k, m, n = symbols('k m n', integer=True)
f, g, h = symbols('f g h', cls=Function)
init_printing()
snip.rv = eval('latex(' + match.group(1).replace('\\', '') \
    .replace('^', '**') \
    .replace('{', '(') \
    .replace('}', ')') + ')')
`
endsnippet

snippet red "red text"
\textcolor{red}{$1}$0
endsnippet

snippet compitem "Compact item list"
\usepackage{enumitem} \setitemize{noitemsep}
endsnippet
    

snippet ivs "ifformat vspace"
\ifformat
\vspace{${1:1}cm}
\fi
$0
endsnippet

snippet grid "Add a grid for drawing graph"
\tinygrid{-${1:10}}{$1}{-${2:10}}{$2}{${3:0.8}}
$0
endsnippet

snippet qq "new question"
\question [${1:5}] $0
endsnippet

snippet qp "question parts"
\begin{parts}
	\part [${1:5}] $0
\end{parts}
endsnippet


