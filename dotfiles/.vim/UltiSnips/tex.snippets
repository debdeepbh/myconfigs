\abs{$1}$0
endsnippet

snippet norm "norm" w
\norm{$1}$0
endsnippet

snippet jap "Japanese brack" w
\jap{$1}$0
endsnippet

snippet hat "wide hat" w
\widehat{$1}$0
endsnippet

snippet tilde "wide tilde" w
