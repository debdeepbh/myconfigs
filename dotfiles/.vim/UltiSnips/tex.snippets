endsnippet

snippet ^ "Description" i
^{$1}$0
endsnippet

snippet _ "Description" i
_{$1}$0
endsnippet

snippet / "frac" i
\frac{$1}{$2}$0
endsnippet

snippet al* "align*" b
\begin{align*}
$0
\end{align*}	
endsnippet

snippet cols "Columns - plural env" b
\begin{columns}
$0
